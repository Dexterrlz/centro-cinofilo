# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (compatibile Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/cinofilo

# ─── Sicurezza ────────────────────────────────────────────────────────────────
# Chiave segreta per firma delle sessioni (generare con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia_questa_chiave_segreta_in_produzione

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tuodominio.it
EMAIL_FROM_NAME=Centro Cinofilo

# ─── Applicazione ─────────────────────────────────────────────────────────────
APP_NAME=Centro Cinofilo
APP_URL=http://localhost:8000
DEBUG=false

# ─── Admin ────────────────────────────────────────────────────────────────────
# Impostare solo al primo avvio per creare l'admin iniziale.
# Rimuovere dopo la prima esecuzione per sicurezza.
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=

# ─── Google OAuth (opzionale) ─────────────────────────────────────────────────
# Ottenere da https://console.cloud.google.com/ → API & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
